{
  "name": "markdown-unwrap-images",
  "displayName": "Markdown Unwrap Images",
  "version": "0.0.0",
  "description": "Unwraps block-level images from paragraph wrappers in VSCode's markdown preview",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": "git@github.com:saeris/markdown.git",
  "publisher": "saeris",
  "main": "./dist/index.js",
  "browser": "./dist/index.js",
  "devDependencies": {
    "@saeris/mdit-unwrap-images": "workspace:*",
    "@types/markdown-it": "^14.1.2",
    "@types/vscode": "^1.118.0"
  },
  "contributes": {
    "markdown.markdownItPlugins": true
  },
  "engines": {
    "vscode": "^1.81.0"
  },
  "bumpy": {
    "buildCommand": "vp pack",
    "publishCommand": "vsce publish",
    "skipNpmPublish": true
  }
}
